{
  "rewrites": [
    {
      "source": "/v/r/google",
      "destination": "/index.html"
    },
    {
      "source": "/v/r/github",
      "destination": "/index.html"
    },
    {
      "source": "/inicio",
      "destination": "/index.html"
    },
    {
      "source": "/v/panel",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
